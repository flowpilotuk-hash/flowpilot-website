# ------------------------------------------------------------------------
# FlowPilot environment variables
# Copy this file to `.env.local` and fill in the values for local dev.
# In production, set these in the Vercel dashboard (Project → Settings →
# Environment Variables). NEVER commit real secrets.
# ------------------------------------------------------------------------

# --- Resend (transactional email) — REQUIRED ---
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender on your Resend-verified domain. Format: "Name <address@domain>"
CONTACT_FROM_EMAIL="FlowPilot <hello@flowpilotuk.com>"

# Internal inbox that receives new-enquiry notifications
CONTACT_TO_EMAIL="hello@flowpilotuk.com"

# --- Rate limiting (OPTIONAL, recommended for production) ---
# Create a free serverless Redis at https://upstash.com and paste the REST
# credentials here. If omitted, a best-effort in-memory limiter is used
# (works, but is per-serverless-instance rather than global).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
