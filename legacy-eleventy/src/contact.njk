---
layout: layouts/base.njk
title: Contact
description: Tell us about your business and we'll take it from here. Reach FlowPilot UK by email or phone — everything can begin by email, with no scheduling software and no pressure.
permalink: /contact/
---
{% from "components/ui.njk" import icon, pageHero %}

{{ pageHero(
  "Contact",
  "Tell us about your business.",
  "We'll take it from here. Send a few details below or email us directly — whatever's easiest. There's no scheduling software to wrestle with and no obligation."
) }}

{# ============================================================= CONTACT #}
<section class="pb-20 sm:pb-24 lg:pb-32">
  <div class="shell">
    <div class="grid items-start gap-12 lg:grid-cols-12 lg:gap-16">
      {# --- Details --- #}
      <div class="reveal lg:col-span-5">
        <div class="space-y-4">
          <a href="mailto:{{ site.contact.email }}" class="flex items-center gap-4 rounded-2xl border border-neutral-200 bg-white p-5 transition-colors hover:border-neutral-300">
            <span class="inline-flex h-12 w-12 flex-none items-center justify-center rounded-xl bg-ink text-chartreuse-400">{{ icon("mail", "h-5 w-5") }}</span>
            <span>
              <span class="block text-sm text-neutral-500">Email us</span>
              <span class="block font-medium text-ink">{{ site.contact.email }}</span>
            </span>
          </a>
          <a href="tel:{{ site.contact.phone }}" class="flex items-center gap-4 rounded-2xl border border-neutral-200 bg-white p-5 transition-colors hover:border-neutral-300">
            <span class="inline-flex h-12 w-12 flex-none items-center justify-center rounded-xl bg-ink text-chartreuse-400">{{ icon("phone", "h-5 w-5") }}</span>
            <span>
              <span class="block text-sm text-neutral-500">Call us</span>
              <span class="block font-medium text-ink">{{ site.contact.phoneDisplay }}</span>
            </span>
          </a>
        </div>

        {# --- Hours --- #}
        <div class="mt-6 rounded-2xl border border-neutral-200 bg-white p-6">
          <div class="flex items-center gap-3">
            <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-chartreuse-100 text-chartreuse-700">{{ icon("clock", "h-5 w-5") }}</span>
            <h2 class="font-semibold text-ink">Business hours</h2>
          </div>
          <dl class="mt-5 divide-y divide-neutral-100">
            {% for h in site.contact.hours %}
              <div class="flex items-center justify-between py-2.5 text-[0.95rem]">
                <dt class="text-neutral-600">{{ h.day }}</dt>
                <dd class="font-medium text-ink">{{ h.time }}</dd>
              </div>
            {% endfor %}
          </dl>
          <p class="mt-4 text-sm leading-relaxed text-neutral-500">
            We reply to most emails within one working day. Everything can begin by
            email — no calls required unless you'd prefer one.
          </p>
        </div>
      </div>

      {# --- Form --- #}
      <div class="reveal reveal-delay-1 lg:col-span-7">
        <div class="rounded-3xl border border-neutral-200 bg-white p-6 shadow-soft sm:p-8">
          <h2 class="text-xl font-semibold text-ink">Send us a message</h2>
          <p class="mt-2 text-[0.95rem] text-neutral-500">
            A few details are all we need to point you in the right direction.
          </p>
          <div class="mt-6">
            {% include "partials/contact-form.njk" %}
          </div>
        </div>
      </div>
    </div>

    {# --- Reassurance strip --- #}
    <div class="mt-16 grid gap-4 sm:grid-cols-3">
      {% set points = [
        { icon: "shield", title: "No pressure", text: "An enquiry is just a conversation. We'll never chase or hard-sell." },
        { icon: "clock-fast", title: "Quick to reply", text: "Most messages answered within one working day, in plain English." },
        { icon: "handshake", title: "Here for the long run", text: "We aim to be your website partner for years, not a one-off job." }
      ] %}
      {% for p in points %}
        <div class="reveal reveal-delay-{{ loop.index0 }} rounded-2xl bg-neutral-50 p-6">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-ink text-chartreuse-400">{{ icon(p.icon, "h-5 w-5") }}</span>
          <h3 class="mt-4 font-semibold text-ink">{{ p.title }}</h3>
          <p class="mt-1 text-sm leading-relaxed text-neutral-500">{{ p.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
