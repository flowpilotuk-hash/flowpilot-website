---
layout: layouts/base.njk
title: Website Packages
description: Three clear website packages for UK small businesses — Essential, Professional and Business Growth — plus optional extras and a Monthly Business Support Plan. Simple, honest pricing.
permalink: /website-packages/
---
{% from "components/ui.njk" import icon, packageCard, check, ctaBand, pageHero %}

{{ pageHero(
  "Website packages",
  "Simple, honest packages.",
  "Three clear options built around what small businesses actually need — with optional extras and ongoing support when you want it. Not sure which fits? We'll recommend one, no pressure."
) }}

{# ============================================================= PACKAGE CARDS #}
<section class="pb-8 sm:pb-12">
  <div class="shell">
    <div class="grid items-stretch gap-6 lg:grid-cols-3 lg:gap-8">
      {% for pkg in packages %}
        <div class="reveal reveal-delay-{{ loop.index0 }}">{{ packageCard(pkg) }}</div>
      {% endfor %}
    </div>
    <p class="mt-6 text-center text-sm text-neutral-500 reveal">
      One-off build prices. Prefer to spread the cost? Ask us about monthly options.
    </p>
  </div>
</section>

{# ============================================================= COMPARISON #}
<section class="section">
  <div class="shell">
    <div class="mx-auto max-w-2xl text-center reveal">
      <span class="eyebrow">Compare in detail</span>
      <h2 class="mt-4 text-display-sm">Everything, side by side.</h2>
      <p class="lede mx-auto mt-4">A clear look at what's included in each package.</p>
    </div>

    <div class="mt-12 overflow-x-auto reveal">
      <table class="w-full min-w-[720px] border-separate border-spacing-0 text-left">
        <thead>
          <tr>
            <th scope="col" class="sticky left-0 z-10 bg-white pb-5 pr-6 align-bottom">
              <span class="text-sm font-medium text-neutral-500">What's included</span>
            </th>
            {% for pkg in packages %}
              <th scope="col" class="px-5 pb-5 align-bottom {{ 'rounded-t-2xl bg-ink' if pkg.recommended }}">
                <div class="{{ 'px-2 pt-4' if pkg.recommended }}">
                  {% if pkg.recommended %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-chartreuse-400 px-2.5 py-0.5 text-[0.7rem] font-semibold text-ink">{{ pkg.badge }}</span>
                  {% endif %}
                  <div class="mt-2 text-base font-semibold {{ 'text-white' if pkg.recommended else 'text-ink' }}">{{ pkg.name }}</div>
                  <div class="mt-1 text-sm {{ 'text-neutral-400' if pkg.recommended else 'text-neutral-500' }}">
                    from <span class="font-semibold {{ 'text-white' if pkg.recommended else 'text-ink' }}">{{ pkg.priceFrom | gbp }}</span>
                  </div>
                </div>
              </th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for row in comparison %}
            <tr class="group">
              <th scope="row" class="sticky left-0 z-10 border-t border-neutral-200 bg-white py-4 pr-6 text-[0.95rem] font-normal text-neutral-700">{{ row.feature }}</th>
              {% for key in ["essential", "professional", "growth"] %}
                {% set val = row[key] %}
                {% set featured = key == "professional" %}
                <td class="border-t border-neutral-200 px-5 py-4 text-center text-[0.95rem] {{ 'bg-ink/[0.02]' if featured }}">
                  {% if val === true %}
                    <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-chartreuse-100 text-chartreuse-700">{{ icon("check", "h-4 w-4") }}</span>
                    <span class="sr-only">Included</span>
                  {% elif val === false %}
                    <span class="text-neutral-300" aria-hidden="true">—</span>
                    <span class="sr-only">Not included</span>
                  {% else %}
                    <span class="font-medium text-ink">{{ val }}</span>
                  {% endif %}
                </td>
              {% endfor %}
            </tr>
          {% endfor %}
          <tr>
            <td class="sticky left-0 bg-white"></td>
            {% for pkg in packages %}
              <td class="px-5 pt-6 text-center {{ 'rounded-b-2xl bg-ink pb-6' if pkg.recommended }}">
                <a href="/contact/" class="{{ 'btn-accent' if pkg.recommended else 'btn-outline' }} w-full">Get started</a>
              </td>
            {% endfor %}
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

{# ============================================================= EXTRAS #}
<section class="section bg-neutral-50">
  <div class="shell">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="reveal lg:col-span-4">
        <span class="eyebrow">Optional extras</span>
        <h2 class="mt-4 text-display-sm">Add only what you need.</h2>
        <p class="mt-4 text-lg leading-relaxed text-neutral-600">
          Every package can be tailored. Add extras now or later — there's never
          any pressure to take more than helps your business.
        </p>
      </div>
      <div class="lg:col-span-8">
        <div class="grid gap-4 sm:grid-cols-2">
          {% for extra in extras %}
            <div class="reveal flex items-start justify-between gap-4 rounded-2xl border border-neutral-200 bg-white p-6 transition-all duration-300 ease-gentle hover:-translate-y-0.5 hover:shadow-soft">
              <div>
                <h3 class="font-semibold text-ink">{{ extra.name }}</h3>
                <p class="mt-1 text-sm leading-relaxed text-neutral-500">{{ extra.description }}</p>
              </div>
              <div class="flex-none text-right">
                {% if extra.priceFrom %}
                  <div class="font-display text-lg font-semibold text-ink">{{ extra.priceFrom | gbp }}</div>
                {% else %}
                  <div class="font-display text-lg font-semibold text-ink">POA</div>
                {% endif %}
                <div class="text-xs text-neutral-400">{{ extra.priceNote }}</div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{# ============================================================= SUPPORT PLAN #}
<section class="section" id="support">
  <div class="shell">
    <div class="overflow-hidden rounded-3xl border border-neutral-200 bg-ink text-neutral-300 on-dark reveal">
      <div class="relative grid gap-10 p-8 sm:p-12 lg:grid-cols-2 lg:gap-16 lg:p-16">
        <div class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-chartreuse-400/10 blur-3xl"></div>
        <div class="relative">
          <span class="eyebrow">After launch</span>
          <h2 class="mt-4 text-display-sm text-white">{{ supportPlan.name }}</h2>
          <p class="lede mt-4">{{ supportPlan.intro }}</p>
          <div class="mt-8 flex items-end gap-2">
            <span class="font-display text-5xl font-semibold text-white">{{ supportPlan.price | gbp }}</span>
            <span class="pb-2 text-neutral-400">{{ supportPlan.priceNote }}</span>
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/contact/" class="btn-accent">Add ongoing support {{ icon("arrow-right", "h-4 w-4") }}</a>
            <a href="/how-we-work/" class="btn-outline">See how it works</a>
          </div>
        </div>
        <div class="relative">
          <ul class="grid gap-4 sm:grid-cols-1">
            {% for f in supportPlan.features %}
              <li class="flex items-start gap-3">
                <span class="mt-0.5 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-chartreuse-400 text-ink">{{ icon("check", "h-4 w-4") }}</span>
                <span class="text-[0.95rem] leading-relaxed text-neutral-200">{{ f }}</span>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

{{ ctaBand("Not sure which package fits?", "Tell us about your business and we'll recommend the right option — in plain English, with no pressure.") }}
