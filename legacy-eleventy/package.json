{
  "name": "flowpilot-uk",
  "version": "1.0.0",
  "description": "FlowPilot UK — professional websites and digital tools for small businesses.",
  "private": true,
  "author": "FlowPilot UK",
  "license": "UNLICENSED",
  "scripts": {
    "clean": "rimraf _site",
    "build:site": "eleventy",
    "build:css": "tailwindcss -i ./src/css/main.css -o ./_site/assets/css/main.css --minify",
    "build": "npm-run-all clean build:site build:css",
    "watch:site": "eleventy --serve --quiet",
    "watch:css": "tailwindcss -i ./src/css/main.css -o ./_site/assets/css/main.css --watch",
    "dev": "npm-run-all build:site --parallel watch:*",
    "start": "npm run dev"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-dev-server": "^2.0.8",
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.17"
  }
}
